# =============================================================================
# Control API Environment
# Copy to /opt/claude-code/env/control-api.env and fill in values
# Provisioned automatically by deploy-claude-code.yml from GitHub secrets
# =============================================================================

# OpenAI API key (for task interpretation via gpt-4o-mini + Whisper STT)
OPENAI_API_KEY=

# Telegram Bot (milestone notifications on task confirm/complete/fail/review)
TG_BOT_TOKEN=
TG_CHAT_ID=

# Bearer token for Control API auth (empty = no auth / dev mode)
CONTROL_API_TOKEN=

# Path to memory server (db.js + migrations)
MEMORY_SERVER_PATH=/opt/claude-code/memory-server
