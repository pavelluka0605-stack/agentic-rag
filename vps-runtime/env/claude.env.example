# =============================================================================
# Claude Code Runtime Environment
# Copy to /opt/claude-code/env/claude.env and fill in values
# =============================================================================

# Required: Anthropic API key for Claude Code
ANTHROPIC_API_KEY=

# Working directory for Claude Code sessions
CLAUDE_WORKSPACE=/opt/claude-code/workspace

# tmux session name
CLAUDE_TMUX_SESSION=claude-code

# Log directory
CLAUDE_LOG_DIR=/opt/claude-code/logs

# Optional: GitHub token for repo operations
GITHUB_TOKEN=

# Optional: default project to open on start
# CLAUDE_DEFAULT_PROJECT=agentic-rag
