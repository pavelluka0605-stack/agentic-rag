[Unit]
Description=Control Bridge API (GPT Actions bridge)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/control-bridge
EnvironmentFile=/opt/control-bridge/.env
ExecStart=/opt/control-bridge/venv/bin/uvicorn app:app --host 0.0.0.0 --port 3000 --workers 2 --log-level info --timeout-keep-alive 30
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
