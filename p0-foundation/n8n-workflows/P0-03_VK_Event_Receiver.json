      "parameters": {
        "rules": {
          "rules": [
            { "outputKey": "message_new", "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" }, "conditions": [{ "id": "cond-msg", "leftValue": "={{ $json.type }}", "rightValue": "message_new", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" } },
            { "outputKey": "wall_reply_new", "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" }, "conditions": [{ "id": "cond-comment", "leftValue": "={{ $json.type }}", "rightValue": "wall_reply_new", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" } },
            { "outputKey": "wall_reply_edit", "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" }, "conditions": [{ "id": "cond-edit", "leftValue": "={{ $json.type }}", "rightValue": "wall_reply_edit", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" } },
            { "outputKey": "system", "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" }, "conditions": [{ "id": "cond-sys", "leftValue": "={{ $json.type }}", "rightValue": "system", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" } }
          ],
          "fallbackOutput": "extra"
        },
        "options": {}
      },
      "id": "switch-type",
