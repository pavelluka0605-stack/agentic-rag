            { "id": "set-text", "name": "text", "value": "={{ $json.message.text }}", "type": "string" },
            { "id": "set-peer", "name": "peer_id", "value": "={{ $json.message.peer_id }}", "type": "number" },
            { "id": "set-date", "name": "date", "value": "={{ $json.received_at }}", "type": "string" }
          ]
        },
        "options": {}
