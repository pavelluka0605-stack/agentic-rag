# ─── P0 Foundation — Environment Variables ───
# Скопируйте в .env и заполните реальными значениями:
#   cp .env.example .env
#   nano .env

# ─── VK API ─────────────────────────────────────
VK_TOKEN=your_vk_community_access_token_here
VK_GROUP_ID=123456789
VK_API_VERSION=5.199

# ─── VK User Long Poll (личные сообщения) ──────
# Токен пользователя со scope: messages,friends,offline
# Получить: https://oauth.vk.com/authorize?client_id=2685278&scope=messages,friends,offline&redirect_uri=https://oauth.vk.com/blank.html&display=page&response_type=token&v=5.199
VK_USER_TOKEN=your_vk_user_token_here

# ─── Google Sheets ──────────────────────────────
GOOGLE_SERVICE_ACCOUNT_FILE=/opt/credentials/google-service-account.json
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# ─── Telegram Bot ───────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_MANAGER_CHAT_ID=123456789
TELEGRAM_LOGIST_CHAT_ID=

# ─── N8N ────────────────────────────────────────
N8N_URL=http://localhost:5678
N8N_API_KEY=
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook

# ─── BlueSales ──────────────────────────────────
BLUESALES_LOGIN=your_bluesales_login
BLUESALES_PASSWORD=your_bluesales_password
